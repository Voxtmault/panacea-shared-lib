# DB Configs
DB_DRIVER=mysql
DB_HOST=host
DB_USER=user
DB_PASSWORD=password
DB_NAME=db_name
DB_PORT=3306
DB_TLS_CONFIG=true
DB_ALLOW_NATIVE_PASSWORDS=true
DB_MULTI_STATEMENTS=false

# Redis Configs
REDIS_HOST=redis_host
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=redis_password
REDIS_EXPIRATION=60 

# Websocket Configs
WS_URL=ws_url
WS_TOKEN=ws_token
WS_RECONNECT_INTERVAL=10 

# Security Config
AES_KEY=key
JWT_KEY=key
JWT_LIFE_SPAN=1 
PASSWORD_MIN_LENGTH=8

# SSL Config
KEY_PATH=key_path
CERT_PATH=cert_path

# File Handling Config
MAX_FILE_SIZE=50 
FILE_ROOT_PATH=/home/andy/go-projects/project-panacea/panacea-shared-lib/files

# General Configs
APP_MODE=devs
APP_PORT=port
APP_LANG=id
APP_TIMEZONE=Asia/Jakarta
APP_NAME=app_name
APP_HOST=app_host
APP_ROOT=app_root

LOG_PATH=./log/server.log
ERR_LOG_PATH=./log/error.log
LOG_MAX_SIZE=30
LOG_MAX_BACKUP=5
LOG_MAX_AGE=30
LOG_COMPRESS=true

# HTTP Timeout Configs
GET_TIMEOUT=10
POST_TIMEOUT=10
PUT_TIMEOUT=10
PATCH_TIMEOUT=10
DELETE_TIMEOUT=10

# GRPC Configs
BPJS_RPC=localhost
PATIENT_RPC=localhost 
FRONTDESK_RPC=localhost
ER_RPC=localhost
PHARMACY_RPC=localhost
POLICLINIC_RPC=localhost
SATUSEHAT_RPC=localhost
LAB_RPC=localhost
